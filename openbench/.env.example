# Copy this file to `openbench/.env` and fill in your own values.
#
#     cp openbench/.env.example openbench/.env
#
# Anything you change here is read by the api / worker / web docker containers
# at startup. After editing, recreate the api container so it picks up the new
# env: `cd openbench && docker compose up -d api`.

# --- Required ---
# Get an Anthropic key at https://console.anthropic.com/settings/keys
# (Optional at boot — you can also set the org-scoped key from the console's
#  "API Keys" page after signing in.)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- App ---
APP_ENV=development
APP_NAME=OpenBench OS
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=OpenBench OS

# --- Auth ---
# Generate a strong secret for production: `openssl rand -hex 32`
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=openbench
POSTGRES_USER=openbench
POSTGRES_PASSWORD=openbench

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=openbench
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_PUBLIC_BASE_URL=http://localhost:9000

# --- AI ---
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_FAST_MODEL=claude-opus-4-7
ANTHROPIC_VISION_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=64000
ANTHROPIC_BETA=

# --- Demo seed (auto-created on first boot) ---
SEED_ORG_NAME=Demo Lab
SEED_ORG_SLUG=demo-lab
SEED_REVIEWER_EMAIL=reviewer@demo.lab
SEED_OPERATOR_EMAIL=operator@demo.lab
SEED_ADMIN_EMAIL=admin@demo.lab
SEED_PASSWORD=Bench!Demo1

# --- Webhook delivery ---
WEBHOOK_SIGNING_SECRET=replace-me

# --- Email notifications (SMTP) — leave SMTP_HOST blank in dev to no-op ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=openbench@localhost
SMTP_FROM_NAME=OpenBench OS

# --- CORS ---
# Browser origins allowed to hit the API. Add http://localhost:3001 if your
# landing page ends up on a different port.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:4028,http://127.0.0.1:4028,http://localhost:1420,tauri://localhost
