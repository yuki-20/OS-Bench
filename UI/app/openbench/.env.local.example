# Copy to `.env.local` to point the console at your API.
#
#     cp UI/app/openbench/.env.local.example UI/app/openbench/.env.local
#
# These are baked into the client bundle at build time (Next.js
# `NEXT_PUBLIC_*` convention) — no secrets here.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=OpenBench OS
